@echo off
REM Build script for Mega Drive Diagnostics ROM (Windows)
REM Requires: vasm68k_mot.exe in PATH

SET SRC=diagnostic.asm
SET OUT=diagnostic.bin

REM Check if vasm68k_mot is available
where vasm68k_mot.exe >nul 2>&1
IF %ERRORLEVEL% NEQ 0 (
    echo Error: vasm68k_mot.exe not found in PATH.
    exit /b 1
)

REM Build ROM
echo Building Mega Drive ROM...
vasm68k_mot.exe -Fbin -o %OUT% %SRC%

IF %ERRORLEVEL% EQU 0 (
    echo Build successful: %OUT%
) ELSE (
    echo Build failed!
    exit /b 1
)